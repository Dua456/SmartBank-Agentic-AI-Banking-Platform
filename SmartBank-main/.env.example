# =============================================================================
# SmartBank — Environment Configuration
# =============================================================================

# --- Core Settings ---
SMARTBANK_ENV=development
SMARTBANK_DEBUG=true
SMARTBANK_LOG_LEVEL=INFO

# --- AI / LLM ---
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx
OPENAI_API_KEY=sk-xxxxxxxxxxxx
CLASSIFICATION_MODEL=claude-sonnet-4-20250514
ASSISTANT_MODEL=claude-haiku-3-20250301
OCR_MODEL=gpt-4o-vision
CONFIDENCE_THRESHOLD=0.65
ESCALATION_THRESHOLD=0.65

# --- Database ---
DB_TYPE=postgresql
DB_HOST=localhost
DB_PORT=5432
DB_NAME=smartbank
DB_USER=smartbank_user
DB_PASSWORD=changeme_prod
DB_SSL_MODE=require
ELASTICSEARCH_HOST=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=smartbank-audit

# --- UiPath Orchestrator ---
UIPATH_ORCHESTRATOR_URL=https://cloud.uipath.com/xxxxxxxxxx
UIPATH_TENANT=smartbank
UIPATH_ORGANIZATION_ID=org_xxxx
UIPATH_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
UIPATH_CLIENT_SECRET=********
UIPATH_ACCOUNT_NAME=smartbank-account

# --- Core Banking System (CBS) Simulation ---
CBS_API_BASE_URL=http://localhost:8080/api/v1
CBS_API_KEY=cbx_api_key_xxxx
CBS_CONNECTION_TIMEOUT=30

# --- Security ---
JWT_SECRET=generate-a-256-bit-secret
JWT_EXPIRY_MINUTES=15
REFRESH_TOKEN_EXPIRY_DAYS=7
AES_ENCRYPTION_KEY=generate-256-bit-key
OAUTH_CLIENT_ID=smartbank-web
OAUTH_CLIENT_SECRET=oauth_secret_xxxx
OAUTH_AUTHORIZE_URL=http://localhost:8080/auth/authorize
OAUTH_TOKEN_URL=http://localhost:8080/auth/token
PKCE_ENABLED=true
CORS_ORIGINS=http://localhost:3000,http://localhost:8000
HSTS_ENABLED=true
HSTS_MAX_AGE=31536000

# --- Notifications ---
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxx
EMAIL_FROM=noreply@smartbank.ai
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxx
TWILIO_PHONE_NUMBER=+1234567890
WHATSAPP_API_TOKEN=EAxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=123456789
FCM_SERVER_KEY=AAAAxxxxxxxxxxxx

# --- OCR / Document AI ---
AZURE_FORM_RECOGNIZER_ENDPOINT=https://xxxxx.cognitiveservices.azure.com/
AZURE_FORM_RECOGNIZER_KEY=xxxxxxxxxxxx
AWS_ACCESS_KEY_ID=AKIAxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
AWS_REGION=ap-southeast-1
FACE_MATCH_CONFIDENCE_THRESHOLD=0.88
FRAUD_RISK_AUTO_REJECT=60
FRAUD_RISK_HUMAN_REVIEW=30
MAX_DOCUMENT_SIZE_MB=10

# --- Open Banking ---
OPEN_BANKING_BASE_URL=https://api.smartbank.ai/v1
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
MTLS_CERT_PATH=/etc/certs/client.crt
MTLS_KEY_PATH=/etc/certs/client.key
MTLS_CA_PATH=/etc/certs/ca.crt
PSD2_TPP_ID=tpp_smartbank_001

# --- Storage ---
STORAGE_BACKEND=azure_blob
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=xxxx
AZURE_STORAGE_CONTAINER=smartbank-documents
AWS_S3_BUCKET=smartbank-documents
S3_REGION=ap-southeast-1

# --- Monitoring ---
SENTRY_DSN=https://xxxxxxxxxxxx@xxxxxxxx.ingest.sentry.io/xxxxxx
PROMETHEUS_PORT=9090
GRAFANA_URL=http://localhost:3001

# --- Demo Mode ---
DEMO_MODE=true
DEMO_CUSTOMER_ID=CUST-DEMO-001
DEMO_ACCOUNT_NUMBER=PK12ABCD0000001234
